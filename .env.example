# Bot Configuration
BOT_TOKEN=your_bot_token_here
BOT_USERNAME=RafflixBot
ADMIN_IDS=12345678,87654321
CHANNEL_ID=-100123456789

# Database (Railway automatically provides DATABASE_URL)
# If local, use: postgresql+asyncpg://user:password@localhost:5432/rafflix
DATABASE_URL=

# Redis (Railway automatically provides REDIS_URL)
# If local, use: redis://localhost:6379/0
REDIS_URL=

# Web App Configuration
WEBAPP_URL=https://your-api-service.up.railway.app
# WEBHOOK_URL is optional, bot currently uses Polling for simplicity
# WEBHOOK_URL=https://your-api-service.up.railway.app/webhook
